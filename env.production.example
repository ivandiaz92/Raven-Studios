# Copy to .env.production on the droplet and fill in real values.
# Do not commit .env.production (it should be in .gitignore).

# Live site URL (SEO, Open Graph, canonical)
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Strapi — your Strapi Cloud URL (must end with /api)
NEXT_PUBLIC_STRAPI_API_URL=https://your-project.strapiapp.com/api
STRAPI_API_TOKEN=

# Contact form (Resend)
RESEND_API_KEY=
CONTACT_EMAIL_TO=hello@yourdomain.com
# CONTACT_FROM=Aspect <contact@yourdomain.com>
